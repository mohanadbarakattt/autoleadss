# AutoLeadss SaaS — local env template. Copy to `.env.local` and fill in real values.
# The app runs fully in demo mode (localStorage, no auth) with everything below unset.

# ---------------------------------------------------------------------------
# Client (bundled by Vite — never put secrets here)
# ---------------------------------------------------------------------------

# Clerk publishable key — the SaaS (/login, /signup, /app) uses Clerk when this is set.
# Value comes from the shared MBAI Clerk app (same value across every MBAI product) — see
# ~/projects/mbai-ecosystem/docs/ENV-CONTRACT.md. This is the exact canonical variable name;
# never rename it or invent a VITE_ variant.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<FILL_ME>

# ---------------------------------------------------------------------------
# Server (Vercel functions under api/ only — NEVER exposed to the client bundle;
# do not add a VITE_/NEXT_PUBLIC_ prefix to any of these)
# ---------------------------------------------------------------------------

# Shared MBAI Clerk app's secret key — verifies the Clerk session token attached to
# authenticated api/ requests (see api/_lib/auth.ts). Canonical name from
# ~/projects/mbai-ecosystem/docs/ENV-CONTRACT.md.
CLERK_SECRET_KEY=<FILL_ME>

# Shared Neon Postgres project (the `mbai` project — see
# ~/projects/mbai-ecosystem/docs/SHARED-DB-DESIGN.md). This app connects as the
# `autoleadss_app` role, scoped to the `autoleadss` schema plus a narrow slice of
# `public`. DATABASE_URL is pooled (runtime queries, used by api/*); DIRECT_URL is
# non-pooled (migrations only — see api/db/migrations/README.md).
DATABASE_URL=<FILL_ME>
DIRECT_URL=<FILL_ME>

# Shared MBAI Model Gateway — optional AI-copy path for the wizard (see
# api/ai-generate.ts and ~/projects/mbai-ecosystem/docs/ENV-CONTRACT.md). Vercel env,
# server-side only — never prefix these with VITE_/NEXT_PUBLIC_, the SPA must never
# hold MBAI_GATEWAY_KEY. When unset, /api/ai-generate returns 503 and the wizard
# falls back to its existing template-only generation (today's demo experience).
MBAI_GATEWAY_URL=<FILL_ME>
MBAI_GATEWAY_KEY=<FILL_ME>

# ---------------------------------------------------------------------------
# Marketing-site contact form only (unrelated to the SaaS product above — predates
# it; see src/components/sections/Contact.tsx). Its own small Supabase project, just
# for the `send-contact-email` edge function. NOT the SaaS's data store — that was
# migrated off Supabase onto the shared Neon backend above.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=<FILL_ME>
VITE_SUPABASE_PUBLISHABLE_KEY=<FILL_ME>
